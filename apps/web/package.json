{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "vite build",
    "format": "prettier --write .",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','coverage','test-results','playwright-report']) fs.rmSync(p,{recursive:true,force:true});\""
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@researchlens/api-client": "workspace:*",
    "@researchlens/ui": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "vite": "^5.4.8"
  }
}
