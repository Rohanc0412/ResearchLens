{
  "name": "@researchlens/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "build": "tsc --noEmit",
    "format": "prettier --write .",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','coverage']) fs.rmSync(p,{recursive:true,force:true});\""
  }
}
