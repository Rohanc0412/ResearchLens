{
  "name": "@researchlens/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "python -m uv --cache-dir ../../.uv-cache run --package researchlens-api python ../../scripts/export_openapi.py --output openapi.json && openapi --input openapi.json --output src/generated --client fetch --useUnionTypes",
    "lint": "eslint src/index.ts --ext .ts,.tsx --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "build": "tsc --noEmit",
    "format": "prettier --write .",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','coverage']) fs.rmSync(p,{recursive:true,force:true});\""
  },
  "devDependencies": {
    "openapi-typescript-codegen": "^0.30.0"
  }
}
