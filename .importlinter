[importlinter]
root_package = researchlens

[importlinter:contract:shared_isolation]
name = Shared code must not depend on business modules
type = forbidden
source_modules =
    researchlens.shared
forbidden_modules =
    researchlens.modules

[importlinter:contract:auth_layering]
name = Auth layering
type = layers
containers = researchlens.modules.auth
layers =
    presentation
    application
    domain

[importlinter:contract:projects_layering]
name = Projects layering
type = layers
containers = researchlens.modules.projects
layers =
    presentation
    application
    domain

