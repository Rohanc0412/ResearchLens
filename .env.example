# ResearchLens Phase 1 environment template.
# This file documents the canonical typed config surface.

# App
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_PHASE=phase-1
APP_API_HOST=127.0.0.1
APP_API_PORT=8000
APP_WORKER_NAME=researchlens-worker

# Database
DATABASE_URL=postgresql+psycopg://researchlens:researchlens@localhost:5432/researchlens
DATABASE_ECHO=false
DATABASE_RUN_MIGRATIONS_ON_STARTUP=false

# Queue
QUEUE_BACKEND=redis
QUEUE_URL=redis://localhost:6379/0
QUEUE_POLL_INTERVAL_SECONDS=5

# Storage
STORAGE_MODE=local
STORAGE_LOCAL_ARTIFACT_ROOT=.data/artifacts
STORAGE_BUCKET=
STORAGE_ENDPOINT=

# Auth
AUTH_ACCESS_TOKEN_SECRET=dev-access-secret-change-me
AUTH_REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me
AUTH_ALLOW_INSECURE_DEV_TOKENS=true

# SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_FROM_NAME=ResearchLens
SMTP_FROM_EMAIL=noreply@example.com

# Retrieval
RETRIEVAL_ENABLED=false
RETRIEVAL_MAX_SOURCES_PER_RUN=20
RETRIEVAL_ALLOW_EXTERNAL_FETCH=false

# LLM
LLM_PROVIDER=disabled
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# Embeddings
EMBEDDINGS_PROVIDER=disabled
EMBEDDINGS_MODEL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_CACHE_ENABLED=true

# Observability
OBSERVABILITY_SERVICE_NAME=researchlens
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_JSON_LOGS=false
OBSERVABILITY_TRACING_ENABLED=false
