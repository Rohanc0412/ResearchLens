# ResearchLens Phase 0 scaffold-only environment template.
# Replace placeholders in later phases with concrete settings.

# App environment
APP_ENV=development
LOG_LEVEL=INFO

# API host/port
API_HOST=127.0.0.1
API_PORT=8000

# Worker environment
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL_SECONDS=5

# Database placeholder
DATABASE_URL=postgresql://user:password@localhost:5432/researchlens

# Queue placeholder
QUEUE_URL=redis://localhost:6379/0

# Storage placeholder
STORAGE_BUCKET=researchlens-local
STORAGE_ENDPOINT=http://localhost:9000

# Auth placeholder
AUTH_ISSUER=https://auth.example.test
AUTH_AUDIENCE=researchlens

# Provider placeholder
PROVIDER_API_BASE_URL=https://provider.example.test
PROVIDER_API_KEY=replace-me

# Observability placeholder
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=https://examplePublicKey@example.ingest.sentry.io/0

