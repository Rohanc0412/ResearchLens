# ResearchLens environment template.
# This file documents the canonical typed config surface.

# App
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_PHASE=phase-5
APP_API_HOST=127.0.0.1
APP_API_PORT=8000
APP_WORKER_NAME=researchlens-worker

# Database
DATABASE_URL=postgresql+psycopg://researchlens:researchlens@localhost:5432/researchlens
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true
DATABASE_RUN_MIGRATIONS_ON_STARTUP=false

# Queue
QUEUE_BACKEND=db
QUEUE_URL=
QUEUE_POLL_INTERVAL_SECONDS=5
QUEUE_LEASE_SECONDS=30
QUEUE_MAX_ATTEMPTS=5
QUEUE_BATCH_SIZE=1
QUEUE_SSE_KEEPALIVE_SECONDS=2
QUEUE_SSE_TERMINAL_GRACE_SECONDS=1
QUEUE_RUN_STUB_STAGE_DELAY_MS=10

# Storage
STORAGE_MODE=local
STORAGE_LOCAL_ARTIFACT_ROOT=.data/artifacts
STORAGE_BUCKET=
STORAGE_ENDPOINT=

# Auth
AUTH_REQUIRED=true
AUTH_DEV_BYPASS_AUTH=false
AUTH_ACCESS_TOKEN_SECRET=dev-access-secret-change-me-32-bytes
AUTH_REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me
AUTH_PASSWORD_RESET_TOKEN_SECRET=dev-password-reset-secret-change-me
AUTH_JWT_ISSUER=researchlens
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_COOKIE_NAME=researchlens_refresh
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_ALLOW_REGISTER=true
AUTH_CLOCK_SKEW_SECONDS=30
AUTH_MFA_CHALLENGE_MINUTES=5
AUTH_MFA_TOTP_ISSUER=ResearchLens
AUTH_MFA_TOTP_PERIOD_SECONDS=30
AUTH_MFA_TOTP_DIGITS=6
AUTH_MFA_TOTP_WINDOW=1
AUTH_PASSWORD_RESET_MINUTES=30
AUTH_ALLOW_INSECURE_DEV_TOKENS=true

# Bootstrap actor
BOOTSTRAP_ACTOR_ENABLED=true
BOOTSTRAP_ACTOR_TENANT_ID=00000000-0000-0000-0000-000000000001
BOOTSTRAP_ACTOR_USER_ID=bootstrap-user

# SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_FROM_NAME=ResearchLens
SMTP_FROM_EMAIL=noreply@example.com

# Retrieval
RETRIEVAL_ENABLED=true
RETRIEVAL_ENABLED_PROVIDERS=["paper_search_mcp","pubmed","europe_pmc","openalex","arxiv"]
RETRIEVAL_PRIMARY_PROVIDER=paper_search_mcp
RETRIEVAL_FALLBACK_PROVIDERS=["pubmed","europe_pmc","openalex","arxiv"]
RETRIEVAL_FALLBACK_THRESHOLD=5
RETRIEVAL_MAX_SOURCES_PER_RUN=20
RETRIEVAL_ALLOW_EXTERNAL_FETCH=false
RETRIEVAL_MAX_OUTLINE_SECTIONS=6
RETRIEVAL_MAX_GLOBAL_QUERIES=3
RETRIEVAL_MAX_QUERIES_PER_SECTION=2
RETRIEVAL_MAX_GLOBAL_QUERIES_TOTAL=20
RETRIEVAL_MAX_RESULTS_PER_PROVIDER_QUERY=10
RETRIEVAL_MAX_CANDIDATES_AFTER_NORMALIZATION=200
RETRIEVAL_MAX_CANDIDATES_SENT_TO_RERANK=60
RETRIEVAL_MIN_SELECTED_SOURCES=5
RETRIEVAL_MAX_SELECTED_SOURCES=20
RETRIEVAL_MAX_CONCURRENT_PROVIDER_SEARCHES=12
RETRIEVAL_MAX_CONCURRENT_ENRICHMENT_FETCHES=8
RETRIEVAL_PROVIDER_TIMEOUT_SECONDS=20
RETRIEVAL_STAGE_SOFT_TIME_BUDGET_SECONDS=170
RETRIEVAL_RANKING_LEXICAL_WEIGHT=1.0
RETRIEVAL_RANKING_EMBEDDING_WEIGHT=0.7
RETRIEVAL_RANKING_RECENCY_WEIGHT=0.2
RETRIEVAL_RANKING_CITATION_WEIGHT=0.3
RETRIEVAL_DIVERSITY_PER_BUCKET_LIMIT=3
RETRIEVAL_INGESTION_CHUNK_SIZE=2000
RETRIEVAL_INGESTION_CHUNK_OVERLAP=200

# LLM
LLM_PROVIDER=disabled
LLM_MODEL=gpt-5-nano
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_OUTPUT_TOKENS=2000
LLM_TEMPERATURE=0.2
LLM_ENABLE_OUTLINE_GENERATION=true
LLM_ENABLE_QUERY_PLANNING=true

# Embeddings
EMBEDDINGS_PROVIDER=disabled
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=
EMBEDDINGS_CACHE_ENABLED=true
EMBEDDINGS_BATCH_SIZE=64
EMBEDDINGS_MAX_CONCURRENT_BATCHES=4
EMBEDDINGS_TIMEOUT_SECONDS=30

# Observability
OBSERVABILITY_SERVICE_NAME=researchlens
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_JSON_LOGS=false
OBSERVABILITY_TRACING_ENABLED=false
