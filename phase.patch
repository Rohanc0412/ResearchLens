-+
-+    async def get_by_name_for_tenant(
-+        self,
-+        *,
-+        tenant_id: UUID,
-+        name: str,
-+    ) -> Project | None:
-+        statement = select(ProjectRow).where(
-+            ProjectRow.tenant_id == tenant_id,
-+            ProjectRow.name == name,
-+        )
-+        row = await self._session.scalar(statement)
-+        if row is None:
-+            return None
